<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="REST.MVVM.Views.MainView"
             Title="MainView"
                 BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- HEADER -->
        <Grid Padding="20,10" ColumnDefinitions="Auto,*,Auto">

            <Label Text="☰" FontSize="22"/>
            <Label Grid.Column="1" Text="Counseling Sessions" Style="{StaticResource HeaderTitle}"/>

            <Frame Grid.Column="2" Padding="5" CornerRadius="20" BackgroundColor="Gray" HorizontalOptions="End" VerticalOptions="Center">
                <StackLayout Orientation="Horizontal" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="👤" FontSize="20"/>
                    <Label Text="MC" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                    <Label Text="✕" TextColor="Red" FontSize="20">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Closed_Click" NumberOfTapsRequired="1"/>
                        </Label.GestureRecognizers>
                    </Label>
                </StackLayout>
            </Frame>

        </Grid>

        <!-- SEARCH -->
        <SearchBar Grid.Row="1" Placeholder="Search students or dates" Margin="20,0"/>

        <!-- FILTER -->
        <HorizontalStackLayout Grid.Row="2" Spacing="10" Margin="20,10">
            <Button Text="All Sessions" BackgroundColor="{StaticResource PrimaryColor}" TextColor="White" CornerRadius="20"/>
            <Button Text="Upcoming" BackgroundColor="#EAEAEA" CornerRadius="20"/>
            <Button Text="Archived" BackgroundColor="#EAEAEA" CornerRadius="20"/>
        </HorizontalStackLayout>

        <!-- COLLECTIONVIEW + Floating Button -->
        <Grid Grid.Row="3">
            <CollectionView Margin="20" ItemsSource="{Binding Sessions}">
                <CollectionView.ItemTemplate>
                    <!-- Your DataTemplate here -->
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- FLOATING BUTTON -->
            <Button Text="+"
                Style="{StaticResource FloatingButton}"
                Clicked="Create_Clicked"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="25"/>
        </Grid>

    </Grid>

</ContentPage>