<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colors -->
    <Color x:Key="PrimaryColor">#F25C05</Color>
    <Color x:Key="PageBackground">#F5F5F5</Color>
    <Color x:Key="CardBackground">White</Color>
    <Color x:Key="StatusBackground">#FFE5D6</Color>

    <!-- Header Title -->
    <Style x:Key="HeaderTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="#333"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

    <!-- Session Name -->
    <Style x:Key="SessionName" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- Session Date -->
    <Style x:Key="SessionDate" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="Gray"/>
    </Style>

    <!-- Session Card -->
    <Style x:Key="SessionCard" TargetType="Frame">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}"/>
        <Setter Property="HasShadow" Value="True"/>
    </Style>

    <!-- Floating Button -->
    <Style x:Key="FloatingButton" TargetType="Button">
        <Setter Property="WidthRequest" Value="60"/>
        <Setter Property="HeightRequest" Value="60"/>
        <Setter Property="CornerRadius" Value="30"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

</ResourceDictionary>